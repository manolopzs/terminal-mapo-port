{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    { "path": "/api/cron/morning", "schedule": "30 13 * * 1-5" },
    { "path": "/api/cron/drawdown", "schedule": "30 14-21 * * 1-5" },
    { "path": "/api/cron/earnings", "schedule": "0 12 * * 0" },
    { "path": "/api/cron/screen", "schedule": "30 21 * * 1-5" }
  ]
}
